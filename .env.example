# NetDash M2 — Environment Variables
# Copy this file to .env and fill in the values for your environment

# Security: API authentication token (required in production)
# Used to authenticate /api/switches/<id>/collect and other management endpoints
API_TOKEN=your_api_token_here

# Application mode: true for demo/development, false for production with real switches
DEMO_MODE=true

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
