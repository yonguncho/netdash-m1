          {
            "tab": "MAC 테이블",
            "columns": ["VLAN", "MAC 주소", "포트"]
          },
          {
            "tab": "ARP 테이블",
            "columns": ["IP 주소", "MAC 주소", "인터페이스"]
          },
          {
            "tab": "History (M3)",
            "note": "M3에서 추가 예정"
          }
        ],
        "technology": "Vanilla JS + CSS (CDN 0, 외부 프레임워크 금지)",
        "api": "3초 주기 GET /api/state → JSON 갱신",
        "resolution": "1920x1080 VDI 최적화",
        "error_states": [
          "수집 대기 (pending): 진행률 표시",
          "수집 실패 (failed): 오류 메시지 + 재시도 버튼"
        ]
      }
    ],
