  "requirements": {
    "functional": [
      {
        "id": "FR-01",
        "name": "다중 스위치 수집 (Collector)",
        "description": "사용자가 여러 VDI 스위치에 SSH 접속해 show 명령 자동 수집 → DB 저장",
        "input": {
          "api_endpoint": "POST /api/switches/<switch_id>/collect",
          "request_body": {
            "username": "admin",
            "password": "***"
          },
          "note": "demo 모드에서는 불필요"
        },
        "output": {
          "response": {
            "status": "queued",
            "switch_id": 123,
            "queue_position": 1
          }
        },
        "implementation": [
          "수집 큐에 (switch_id, username, password) 등록",
          "_worker_loop() MAX_CONCURRENT=3 스레드 처리",
          "netmiko ConnectHandler(device_type=<type>) SSH 연결",
          "각 COMMANDS 실행 (show interfaces, show mac, show arp 등)",
          "terminal length 0 설정으로 페이지 제약 제거",
          "raw_outputs/<switch_name>/<YYYYmmdd_HHMMSS>/ 에 텍스트 저장",
          "show 파싱 전 DB snapshot, ports, mac_entries, arp_entries 테이블 기록",
          "switches.status: pending → collecting → done / failed 상태 전이",
          "완료 시 모든 show 파싱 결과를 DB 저장"
        ],
        "error_handling": [
          "SSH 연결 실패/타임아웃 → status=failed, error 필드 기록, snapshot은 생성 안함",
          "show 명령 출력이 비어 있음 → 해당 항목 skip (예: show logging 없음)",
          "demo 모드: fixtures/<type>/ 에서 미리 저장된 show 출력 사용 (SSH 0)"
        ]
      },
      {
        "id": "FR-02",
        "name": "파서 3개 (Cisco/Arista/Extreme)",
        "description": "show 텍스트 → JSON 정규화",
        "supported_types": ["cisco_ios", "arista_eos", "extreme_exos"],
        "commands": {
          "status": "show interfaces",
          "descr": "show interfaces description",
          "mac": "show mac address-table dynamic",
          "arp": "show arp",
          "log": "show logging | include changed state"
        },
        "output_schema": {
          "ports": [
            {
              "switch_id": 123,
              "name": "Gi1/0/1",
              "status": "up",
              "vlan": 10,
              "speed": "1000M",
              "descr": "VLAN10-PC01"
            }
          ],
          "macs": [
            {
              "switch_id": 123,
              "vlan": 1,
              "mac": "00:11:22:33:44:55",
              "port": "Gi1/0/1",
              "type": "dynamic"
            }
          ],
          "arps": [
            {
              "switch_id": 123,
              "ip": "10.0.1.100",
              "mac": "00:11:22:33:44:55",
              "interface": "Gi1/0/1"
            }
          ]
        },
        "accuracy_target": "95% (fixture 기준)",
        "notes": [
          "Extreme EXOS 포트 표기: 1:12 (1/0/1로 정규화 필요)",
          "fixtures/<type>/ 에 미리 수집한 show 출력 저장 후 정확도 검증",
          "불완전한 출력 skip (재시도 불가)"
        ]
      },
      {
        "id": "FR-03",
        "name": "상관 분석 (Correlator)",
        "description": "ARP + MAC 데이터로 IP → 호스트 위치 추론",
        "logic": [
          "1. 모든 스위치의 MAC을 수집 → MAC 테이블 구성",
          "2. 같은 MAC이 여러 포트에 나타나면 (루프/BPDU 등) FIFO 선택 (최근 4시간 기준)",
          "3. ARP에서 IP → MAC 매핑",
          "4. 각 IP에 대해: MAC이 switch_id/port에 위치 → host[ip] = {mac, switch_id, port, located: true}",
          "5. ARP에는 있지만 MAC 테이블에 없으면 → located: false, reason: 'MAC not found'"
        ],
        "output_schema": {
          "hosts": {
            "10.0.1.100": {
              "mac": "00:11:22:33:44:55",
              "switch_id": 123,
              "switch_name": "CORE-SW01",
              "port": "Gi1/0/5",
              "located": true,
              "confidence": 0.95
            },
            "10.0.1.101": {
              "mac": "00:11:22:33:44:66",
              "switch_id": null,
              "port": null,
              "located": false,
              "reason": "MAC not found in any port"
            }
          }
        },
        "accuracy_target": "85% (데모 샘플)",
        "edge_cases": [
          "같은 MAC이 여러 포트: FIFO (4시간 내 최근)",
          "ARP는 있지만 MAC 없음: located=false",
          "MAC은 있지만 ARP 없음: 호스트 항목 생성 안함 (IPv6 등)",
          "MAC 중복 임계값: config.yaml UPLINK_MAC_THRESHOLD 설정"
        ],
        "test_criteria": [
          "demo 5개 IP 위치 추론",
          "실제 샘플 3개, 오류 15개 → 85% 정확도"
        ]
      },
      {
        "id": "FR-04",
        "name": "UI 읽기 화면 (Switch Detail View)",
        "description": "Flask 웹 UI: 포트/MAC/ARP 탭 표시 + 3초 폴링",
        "layout": [
